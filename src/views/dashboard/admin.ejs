<%- include('../partials/header') %>
<main class="admin-dashboard-container">
    <h1>Hello, <%= user.name %></h1>
    <section class="admin-widget-container">
        <div class="dashboard-user-info-container">
            <h2>Your Account Information</h2>
            <div class="user-detail-container">
                <div class="user-detail">
                    <span class="label">Name:</span>
                    <span class="value"><%= user.name %></span>
                </div>
                <div class="user-detail">
                    <span class="label">Email:</span>
                    <span class="value"><%= user.email %></span>
                </div>
                <div class="user-detail">
                    <span class="label">Address:</span>
                    <%if(user.address) { %>
                        <span class="value"><%= user.address %></span>
                        <% } else { %>
                            <span class="value">Not listed</span>
                        <% } %>
                </div>
                <div class="user-detail">
                    <span class="label">Role:</span>
                    <span class="value"><%= user.roleName %></span>
                </div>
                <div class="user-detail">
                    <span class="label">Created at:</span>
                    <span class="value"><%= new Date(user.created_at).toLocaleDateString() %></span>
                </div>
            </div>
            <% 
                const currentUser = typeof isLoggedIn !== 'undefined' && isLoggedIn ? user : null;
            %>
            <% if(currentUser) {%>
                <a class="user-edit-btn" href="/dashboard/profile/edit">Edit Account Information</a>
            <% } %>
        </div>

        <!-- list all users with edit options -->
        <% if (users && users.length > 0) { %>
            <div class="all-user-container">
                <h2>All Users</h2>
                <div class="user-container">
                    <% users.forEach(listUser => { %>
                        <% 
                            const currentUser = typeof isLoggedIn !== 'undefined' && isLoggedIn ? user : null;
                            const canEdit = currentUser && (currentUser.roleName.toLowerCase() === 'admin');
                        %>
                        <div class="user-card">
                            <h3><%= listUser.name %></h3>
                            <p>Email: <%= listUser.email %></p>
                            <p>Address: <%= listUser.address ? listUser.address : "Not listed" %></p>
                            <p>Role: <%= listUser.roleName %></p>

                            <% if (canEdit) { %>
                                    <a class="user-edit-btn" href="/dashboard/admin/<%= listUser.id %>/edit">Edit</a>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            </div>
        <% } else { %>
            <p class="no-users">No users registered yet.</p>
        <% } %>

        <!-- see all contact form  -->
        <div class="contact-forms-container">
            <h2>Contact Messages</h2>
            <% if(contactForms && contactForms.length > 0) { %>
                <div class="form-container">
                    <% contactForms.forEach(form => { %>
                        <a href="/contact/<%= form.contactId %>" class="form-card <%= form.status === 'unread' ? 'unread' : 'read' %>">
                            <h3>Subject: <%= form.subject %></h3>
                            <p>Message: <%= form.message.slice(0,10) %>...</p>
                            <!-- <details class="sender-info">
                                <summary>Sender Info</summary>
                                <div>
                                    <span>Sender: <%= form.userName ? form.userName : 'not listed' %></span>
                                    <span>Sender's Email: <%= form.userEmail ? form.userEmail : 'not listed' %></span>
                                </div>
                            </details> -->
                            <!-- <p class="contact-form-status"><%= form.status %></p> -->
                        </a>
                    <% }) %>
                </div>
            <% } else { %>
                <p>No messages yet.</p>
            <% } %>
        </div>

    </section>
    <a class="homepage-link" href="/">Return to Homepage</a>
</main>
<%- include('../partials/footer') %>